# =============================================================================
# .dockerignore - Files/folders excluded from Docker build context
# =============================================================================
# Purpose: reduce image size, speed up 'docker build', prevent secrets leak.

# --- Secrets & environment ---
.env
.env.*
!.env.example
*.pem
*.key
*.token
openai_key.txt

# --- Git ---
.git
.gitignore
.gitattributes

# --- Python cache & venv ---
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# --- Model checkpoints (downloaded at runtime, NOT baked in) ---
checkpoints/
*.safetensors
*.ckpt
*.bin
hf_cache/

# --- Trained outputs (bạn muốn giữ local, không upload) ---
output/
runs/
lora_output/
*.log
sidestep.log

# --- Preprocessed tensors (regenerate on Vast.ai) ---
# UNCOMMENT next line if you have preprocessed tensors and don't want to bundle
# datasets/vinahouse/phase_a/tensors/

# --- Datasets: NEVER baked into image (transferred via rsync at runtime) ---
# Data lives on local as source-of-truth; only tensors are rsync'd to instances.
# This keeps the image small (was accidentally baking ~30GB of phase_b tensors).
datasets/

# --- Local backups of trained adapters (kept on local only) ---
vast_backup/
output_docker_test/

# --- Gradio outputs (generated at runtime, don't bundle) ---
gradio_outputs/
outputs/
tmp/
temp/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker artifacts ---
Dockerfile.local
docker-compose.override.yml

# --- Notebooks with potentially large outputs ---
*.ipynb_checkpoints
